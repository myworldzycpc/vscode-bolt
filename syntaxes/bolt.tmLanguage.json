{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Bolt",
	"scopeName": "source.bolt",
	"patterns": [
		{
			"include": "#comments"
		}
	],
	"repository": {
		"comments": {
			"name": "comment.line.number-sign.bolt",
			"begin": "\\#",
			"end": "$"
		}
	}
}